{
  "buildCommand": "npm install && npx prisma generate --schema=backend/prisma/schema.prisma && npm run build --workspace=frontend",
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/api/index.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/backend/api/index" },
    { "source": "/health",     "destination": "/backend/api/index" },
    { "source": "/(.*)",       "destination": "/index.html" }
  ]
}
